generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id          Int       @id @default(autoincrement())
  nom         String
  email       String    @unique
  motDePasse  String    @map("mot_de_passe")
  role        Role      @default(client)
  createdAt   DateTime  @default(now()) @map("created_at")
  commandes   Commande[]

  @@map("users")
}

model Produit {
  id              Int              @id @default(autoincrement())
  nom             String
  description     String?          @db.Text
  prix            Decimal          @db.Decimal(10,2)
  image           String?
  disponible      Boolean          @default(true)
  createdAt       DateTime         @default(now()) @map("created_at")
  lignesCommande  LigneCommande[]

  @@map("produits")
}

model Commande {
  id               Int              @id @default(autoincrement())
  userId           Int              @map("user_id")
  statut           Statut           @default(en_attente)
  total            Decimal          @db.Decimal(10,2)
  adresseLivraison String?          @map("adresse_livraison")
  createdAt        DateTime         @default(now()) @map("created_at")
  user             User             @relation(fields: [userId], references: [id])
  lignesCommande   LigneCommande[]

  @@map("commandes")
}

model LigneCommande {
  id           Int      @id @default(autoincrement())
  commandeId   Int      @map("commande_id")
  produitId    Int      @map("produit_id")
  quantite     Int
  prixUnitaire Decimal  @db.Decimal(10,2) @map("prix_unitaire")
  commande     Commande @relation(fields: [commandeId], references: [id])
  produit      Produit  @relation(fields: [produitId], references: [id])

  @@map("lignes_commande")
}

enum Role {
  client
  admin
}

enum Statut {
  en_attente
  confirmee
  en_preparation
  prete
  livree
  annulee
}